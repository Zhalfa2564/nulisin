# ===========================================
# NULISIN - ENVIRONMENT VARIABLES
# ===========================================
# Salin file ini menjadi .env.local dan isi nilai yang sesuai.
# Semua variabel bersifat OPSIONAL — app tetap berjalan tanpa konfigurasi apa pun.

# Google Analytics 4 Measurement ID
# Hanya aktif di production build (npm run build + preview/deploy).
# Dapatkan dari: Google Analytics > Admin > Data Streams > Measurement ID
# Contoh: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Sentry DSN (Data Source Name)
# Hanya aktif jika diisi. App tetap berjalan normal tanpa Sentry.
# Dapatkan dari: Sentry > Project Settings > Client Keys (DSN)
# Contoh: https://xxx@sentry.io/123
VITE_SENTRY_DSN=

# App version (opsional, digunakan sebagai release tag di Sentry)
VITE_APP_VERSION=0.0.0

# Base URL aplikasi (opsional)
# Digunakan untuk canonical URL, Open Graph, sitemap, dan structured data.
# Default: https://nulisin.app
# Contoh: https://my-custom-domain.com
VITE_APP_URL=
